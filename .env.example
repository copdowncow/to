# ================================================
# СКОПИРУЙТЕ ЭТОТ ФАЙЛ В .env И ЗАПОЛНИТЕ ЗНАЧЕНИЯ
# ================================================

# Supabase (supabase.com -> Settings -> API)
SUPABASE_URL=https://ВАШ_ПРОЕКТ.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ваш-service-role-key
SUPABASE_ANON_KEY=ваш-anon-key

# Сервер
PORT=3000
NODE_ENV=production
